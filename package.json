{
  "name": "toolhub",
  "version": "1.0.0",
  "description": "Free Online Tools Suite - Video, PDF, and Conversion Tools",
  "private": true,
  "scripts": {
    "dev": "cd frontend && npm run dev",
    "build": "cd frontend && npm run build",
    "preview": "cd frontend && npm run preview",
    "deploy": "npm run build && npx wrangler pages deploy frontend/dist",
    "backend": "node backend/src/index.js",
    "dev:all": "concurrently \"npm run dev\" \"npm run backend\"",
    "setup": "cd frontend && npm install && cd ../backend && npm install"
  },
  "dependencies": {
    "vue": "^3.4.21",
    "vue-router": "^4.3.0",
    "pinia": "^2.1.7",
    "vue-i18n": "^9.10.2",
    "lucide-vue-next": "^0.344.0",
    "@ffmpeg/ffmpeg": "^0.12.10",
    "@ffmpeg/util": "^0.12.1",
    "pdf-lib": "^1.17.1",
    "file-saver": "^2.0.5",
    "axios": "^1.6.7"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.0.4",
    "vite": "^5.1.4",
    "tailwindcss": "^3.4.1",
    "postcss": "^8.4.35",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.2"
  }
}
